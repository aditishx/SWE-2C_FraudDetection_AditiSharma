{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://shieldpay.in/schemas/rule/v1",
  "title": "FraudDetectionRule",
  "description": "JSON Schema for validating fraud detection rule definitions at save time",
  "type": "object",
  "required": ["name", "category", "severity", "scope", "conditions", "actions", "effective_date"],
  "additionalProperties": false,
  "properties": {
    "rule_id":    { "type": "string" },
    "version":    { "type": "integer", "minimum": 1 },
    "name":       { "type": "string", "minLength": 3, "maxLength": 100 },
    "description":{ "type": "string", "maxLength": 500 },
    "category":   { "type": "string", "enum": ["VELOCITY","AMOUNT","GEOGRAPHIC","MCC","WATCHLIST","BEHAVIOURAL","DEVICE"] },
    "severity":   { "type": "string", "enum": ["LOW","MEDIUM","HIGH","CRITICAL"] },
    "author":     { "type": "string" },
    "created_at": { "type": "string", "format": "date-time" },
    "effective_date": { "type": "string", "format": "date" },
    "expiry_date":    { "type": ["string","null"], "format": "date" },
    "status":     { "type": "string", "enum": ["DRAFT","REVIEW","APPROVED","ACTIVE","DEPRECATED","RETIRED"] },
    "max_evaluation_time_ms": { "type": "integer", "minimum": 1, "maximum": 50, "default": 10 },
    "scope":      { "type": "string", "enum": ["CARDHOLDER","MERCHANT","TERMINAL","NETWORK","DEVICE"] },
    "conditions": { "$ref": "#/definitions/ConditionNode" },
    "actions": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/definitions/Action" }
    },
    "ab_test": {
      "type": "object",
      "properties": {
        "enabled":           { "type": "boolean" },
        "shadow_mode":       { "type": "boolean" },
        "traffic_split_pct": { "type": "integer", "minimum": 1, "maximum": 50 },
        "comparison_days":   { "type": "integer", "minimum": 1, "maximum": 30 }
      }
    }
  },
  "definitions": {
    "ConditionNode": {
      "oneOf": [
        { "$ref": "#/definitions/LogicalNode" },
        { "$ref": "#/definitions/LeafNode" }
      ]
    },
    "LogicalNode": {
      "type": "object",
      "required": ["operator", "conditions"],
      "properties": {
        "operator":   { "type": "string", "enum": ["AND","OR","NOT"] },
        "conditions": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/definitions/ConditionNode" }
        }
      }
    },
    "LeafNode": {
      "type": "object",
      "required": ["field", "operator", "value"],
      "properties": {
        "field":    { "type": "string" },
        "operator": { "type": "string", "enum": ["eq","neq","gt","gte","lt","lte","in","not_in","between","regex","exists"] },
        "value":    {},
        "temporal_window": {
          "type": "object",
          "required": ["function", "duration_minutes"],
          "properties": {
            "function":         { "type": "string", "enum": ["count","sum","avg","max","min","distinct_count"] },
            "duration_minutes": { "type": "integer", "minimum": 1, "maximum": 1440 },
            "scope_field":      { "type": "string" }
          }
        }
      }
    },
    "Action": {
      "type": "object",
      "required": ["type"],
      "properties": {
        "type": { "type": "string", "enum": ["FLAG","BLOCK","SCORE_ADJUST","NOTIFY","STEP_UP_AUTH"] },
        "params": { "type": "object" }
      }
    }
  }
}
